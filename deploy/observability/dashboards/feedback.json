      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(r.owner || '/' || r.name, t.repository_id::text) AS \"repository\", rc.file AS \"file\", rc.line AS \"line\", coalesce(nullif(f->>'priority',''),'P2') AS \"priority\", coalesce(nullif(f->>'category',''),'correctness') AS \"category\", f->>'title' AS \"finding\", count(*) AS \"downvotes\" FROM review_feedback rf JOIN review_comments rc ON rc.github_comment_id = rf.github_comment_id AND rc.kind = rf.comment_kind JOIN reviews rv ON rv.task_id = rc.task_id JOIN tasks t ON t.id = rc.task_id LEFT JOIN repositories r ON r.id = t.repository_id CROSS JOIN LATERAL jsonb_array_elements(rv.findings) f WHERE rc.kind = 'inline' AND f->>'file' = rc.file AND f->>'line' = rc.line::text AND rf.reaction = '-1' AND $__timeFilter(rf.created_at) GROUP BY r.owner, r.name, t.repository_id, rc.file, rc.line, f->>'priority', f->>'category', f->>'title' ORDER BY count(*) DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Most down-voted findings",
