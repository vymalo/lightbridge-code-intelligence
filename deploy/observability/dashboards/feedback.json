          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT coalesce(nullif(f->>'category',''),'correctness') AS metric, count(*) AS value FROM review_feedback rf JOIN review_comments rc ON rc.github_comment_id = rf.github_comment_id AND rc.kind = rf.comment_kind JOIN reviews rv ON rv.task_id = rc.task_id JOIN tasks t ON t.id = rc.task_id LEFT JOIN repositories r ON r.id = t.repository_id CROSS JOIN LATERAL jsonb_array_elements(rv.findings) f WHERE rc.kind = 'inline' AND f->>'file' = rc.file AND f->>'line' = rc.line::text AND rf.reaction = '-1' AND $__timeFilter(rf.created_at) GROUP BY 1 ORDER BY value DESC",
          "refId": "A"
        }
      ],
      "title": "\ud83d\udc4e by finding category",
      "transformations": [],
      "transparent": false,
      "type": "bargauge"
