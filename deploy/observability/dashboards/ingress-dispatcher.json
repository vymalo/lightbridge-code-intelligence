      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) FROM tasks WHERE status = 'queued'",
          "refId": "A"
        }
      ],
      "title": "Queue backlog",
      "transformations": [],
      "transparent": false,
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) FROM tasks WHERE status = 'running' AND lease_expires_at < now()",
          "refId": "A"
        }
      ],
      "title": "Stuck running (lease expired)",
      "transformations": [],
      "transparent": false,
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum(count_over_time(${stream} |= \"invalid webhook signature\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Signature failures ($__range)",
      "transformations": [],
      "transparent": false,
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "sum(count_over_time(${stream} |= \"duplicate delivery\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Duplicate deliveries ($__range)",
      "transformations": [],
      "transparent": false,
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(received_at, $__interval), count(*) AS \"deliveries\" FROM github_deliveries WHERE $__timeFilter(received_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Deliveries received",
      "transformations": [],
      "transparent": false,
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT attempts::text AS metric, count(*) AS value FROM tasks GROUP BY attempts ORDER BY attempts",
          "refId": "A"
        }
      ],
      "title": "Task attempts distribution",
      "transformations": [],
      "transparent": false,
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "options": null,
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT t.started_at AS \"dispatched\", t.job_name, t.status, t.attempts, t.lease_owner, coalesce(r.owner || '/' || r.name, t.repository_id::text) AS \"repository\" FROM tasks t LEFT JOIN repositories r ON r.id = t.repository_id WHERE t.job_name IS NOT NULL ORDER BY t.started_at DESC NULLS LAST LIMIT 100",
          "refId": "A"
        }
      ],
      "title": "Recently dispatched",
      "transformations": [],
      "transparent": false,
      "type": "table"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": false,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "${stream} | json | level = \"ERROR\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent errors",
      "transformations": [],
      "transparent": false,
      "type": "logs"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": [
    "lightbridge",
    "generated"
  ],
  "templating": {
    "list": [
      {
        "auto": false,
        "auto_count": 30,
        "auto_min": "10s",
        "hide": 0,
        "id": "00000000-0000-0000-0000-000000000000",
        "includeAll": false,
        "label": "Loki stream",
        "multi": false,
        "name": "stream",
        "query": "{app=~\"lightbridge.*\"}",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "Lightbridge \u2014 Ingress & Dispatcher",
  "uid": "lci-ingress-dispatcher"
}
