          "rawQuery": true,
          "rawSql": "WITH rf AS (  SELECT rv.task_id, rv.created_at, je AS f   FROM reviews rv, jsonb_array_elements(rv.findings) je) SELECT coalesce(nullif(f->>'category',''), 'correctness') AS metric, count(*) AS value FROM rf WHERE $__timeFilter(rf.created_at) GROUP BY 1 ORDER BY value DESC",
