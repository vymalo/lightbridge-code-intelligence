      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_POSTGRES}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT rv.created_at AS \"reviewed\", coalesce(r.owner || '/' || r.name, t.repository_id::text) AS \"repository\", t.target_id AS \"pr\", jsonb_array_length(rv.findings) AS \"findings\", rv.inline_count AS \"inline\", rv.deferred_count AS \"deferred\", rv.out_of_scope_count AS \"out_of_scope\", (SELECT coalesce(sum(prompt_tokens + completion_tokens), 0) FROM agent_transcript tr WHERE tr.task_id = rv.task_id) AS \"tokens\", (SELECT coalesce(max(seq) + 1, 0) FROM agent_transcript tr WHERE tr.task_id = rv.task_id) AS \"turns\" FROM reviews rv JOIN tasks t ON t.id = rv.task_id LEFT JOIN repositories r ON r.id = t.repository_id WHERE $__timeFilter(rv.created_at) ORDER BY rv.created_at DESC LIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Recent reviews",
      "transformations": [],
      "transparent": false,
      "type": "table"
