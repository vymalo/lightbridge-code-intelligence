        },
        "hide": 0,
        "id": "00000000-0000-0000-0000-000000000000",
        "includeAll": false,
        "label": "Repository",
        "multi": false,
        "name": "repo",
        "query": "SELECT __text, __value FROM (  SELECT 'All' AS __text, '' AS __value, 0 AS ord   UNION ALL   SELECT owner || '/' || name AS __text, owner || '/' || name AS __value, 1 AS ord   FROM repositories) t ORDER BY ord, __text",
        "skipUrlSync": false,
        "type": "query"
      },
