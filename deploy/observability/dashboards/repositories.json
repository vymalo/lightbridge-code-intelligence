          "rawQuery": true,
          "rawSql": "SELECT r.owner || '/' || r.name AS \"repository\", ri.branch, ri.status, ri.commit_sha, ri.started_at, ri.completed_at FROM repo_index ri JOIN repositories r ON r.id = ri.repository_id ORDER BY ri.completed_at DESC NULLS LAST LIMIT 200",
