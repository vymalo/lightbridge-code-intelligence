          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT r.owner || '/' || r.name AS \"repository\", r.default_branch AS \"branch\", r.active, count(t.id) AS \"tasks\", count(t.id) FILTER (WHERE t.status = 'failed') AS \"failed\", count(t.id) FILTER (WHERE t.status IN ('queued', 'running')) AS \"in_flight\", max(t.created_at) AS \"last_task\" FROM repositories r LEFT JOIN tasks t ON t.repository_id = r.id GROUP BY r.id, r.owner, r.name, r.default_branch, r.active ORDER BY count(t.id) DESC",
          "refId": "A"
        }
