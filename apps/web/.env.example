# Web app OIDC client config (ADR-0014). Copy to .env.local for local dev.
# In dev these point at the Keycloak container from compose.yaml (`just up`).

# OIDC provider (Keycloak realm). Used for discovery, login redirect, and token validation.
OIDC_ISSUER=http://localhost:8081/realms/lightbridge

# Client id (pre-seeded in deploy/keycloak/realm-lightbridge.json). The dev realm uses a PUBLIC
# client (PKCE only), so no secret is needed locally. For a CONFIDENTIAL client in production, set
# OIDC_CLIENT_SECRET (kept in a secret store, never committed) and mark the client confidential.
OIDC_CLIENT_ID=lightbridge-web
# OIDC_CLIENT_SECRET=

# Where Keycloak redirects back after login, and after logout.
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# Expected access-token audience (the realm adds this via an audience mapper). Optional on the web
# tier; the control plane (resource server) enforces it.
OIDC_AUDIENCE=lightbridge-api

# Optional overrides:
# OIDC_SCOPE="openid profile email"
# OIDC_JWKS_URI=http://localhost:8081/realms/lightbridge/protocol/openid-connect/certs
